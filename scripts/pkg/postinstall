#!/bin/bash
# postinstall (driver component pkg)
#
# Restart coreaudiod so the freshly installed HAL driver loads and the
# virtual devices appear (docs/requirements.md §10). Runs as root inside
# Installer. On newer macOS SIP blocks kickstart of coreaudiod; killall +
# launchd respawn is the supported fallback (same as scripts/install-driver.sh).

if ! launchctl kickstart -kp system/com.apple.audio.coreaudiod 2>/dev/null; then
    killall coreaudiod 2>/dev/null || true
fi

exit 0
